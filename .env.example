# このファイルをコピーして .env を作成し、値を埋めてください。
# .env は Git に含めません（.gitignore 済み）。

# Hugging Face（話者分離に必要） https://huggingface.co/settings/tokens
HF_TOKEN=

# 任意: WhisperX の文字起こしモデル（デフォルト large-v3）。メモリが足りない環境では base や small
# WHISPERX_ASR_MODEL=base

# 任意: ASR の計算タイプ（CPU でメモリを抑えたいとき int8 を試す）
# WHISPERX_COMPUTE_TYPE=int8

# 任意: 文字起こしのバッチサイズ（ピークを下げるなら 1）
# WHISPERX_BATCH_SIZE=1

# 任意: pyannote パイプライン名（WhisperX / HF の対応を確認のこと）。未設定で WhisperX 既定
# WHISPERX_DIARIZE_MODEL=pyannote/speaker-diarization-community-1

# 任意: 話者分離（pyannote）をスキップ（Streamlit Cloud の OOM 対策。全セグメント同一話者ラベルになる）
# TRANSCRIPTION_SKIP_DIARIZATION=true
# 任意: スキップ時の話者表示名（デフォルト SPEAKER_00）
# TRANSCRIPTION_DEFAULT_SPEAKER=SPEAKER_00

# 任意: データ保存のルート（未設定時はプロジェクト直下）
# TRANSCRIPTION_BASE_DIR=

# 任意: OpenAI を使う場合
# OPENAI_API_KEY=
