# このファイルをコピーして .env を作成し、値を埋めてください。
# .env は Git に含めません（.gitignore 済み）。

# AssemblyAI（必須）https://www.assemblyai.com/dashboard
# Streamlit Cloud では Secrets の ASSEMBLYAI_API_KEY でも可
ASSEMBLYAI_API_KEY=

# 任意: Groq（要約）https://console.groq.com/keys — Streamlit Secrets の GROQ_API_KEY でも可
# GROQ_API_KEY=

# 任意: 認識モデル — universal（高精度・既定） / nano（速度優先）。Streamlit Secrets でも可
# ASSEMBLYAI_SPEECH_MODEL=universal
# ASSEMBLYAI_SPEECH_MODEL=nano

# 任意: データ保存のルート（未設定時はプロジェクト直下）
# TRANSCRIPTION_BASE_DIR=
