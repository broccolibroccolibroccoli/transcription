# このファイルをコピーして .env を作成し、値を埋めてください。
# .env は Git に含めません（.gitignore 済み）。

# Hugging Face（話者分離に必要） https://huggingface.co/settings/tokens
HF_TOKEN=

# 任意: WhisperX の文字起こしモデル（デフォルト large-v3）。メモリが足りない環境では base や small
# WHISPERX_ASR_MODEL=base

# 任意: データ保存のルート（未設定時はプロジェクト直下）
# TRANSCRIPTION_BASE_DIR=

# 任意: OpenAI を使う場合
# OPENAI_API_KEY=
